{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Next.js: dev + Chrome",
      "configurations": ["Next.js: launch Chrome"]
    }
  ],
  "configurations": [
    {
      "name": "Next.js: dev server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/next",
      "args": ["dev", "--turbopack"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "runtimeExecutable": "node"
    },
    {
      "name": "Next.js: build",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/next",
      "args": ["build"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "production"
      },
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "Next.js: launch Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "dev",
      "url": "http://localhost:3000/en",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://_N_E/./src/*": "${workspaceFolder}/src/*",
        "webpack://_N_E/*": "${workspaceFolder}/*"
      }
    }
  ]
}
